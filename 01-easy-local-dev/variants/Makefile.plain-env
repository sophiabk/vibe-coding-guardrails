# acme-app — local development (plain .env file, no secrets manager).
# Simplest option: secrets live in a gitignored .env file and are loaded into the
# environment before each command. Good for solo projects / getting started.
#
#   make dev / make stop / make reset / make doctor
#
# NOTE: keep .env out of git. Commit .env.example (placeholders) instead.

.PHONY: dev stop reset doctor _check-docker _check-node _check-env _db-up _migrate _seed

# Load .env into the environment for any recipe that needs it.
# `set -a` exports every variable defined while sourcing the file.
LOAD_ENV := set -a; . ./.env; set +a;

# ---------- main targets ----------

dev: doctor _db-up _migrate _seed
	@echo "→ Starting the app at http://localhost:3000 (Ctrl+C to stop)"
	@$(LOAD_ENV) yarn dev

stop:
	@PG_PASSWORD=dummy docker compose down

reset: doctor
	@$(MAKE) _db-up
	@$(LOAD_ENV) npx prisma migrate reset --force
	@echo "✓ Local database reset"

# ---------- doctor ----------

doctor: _check-docker _check-node _check-env
	@echo "✓ All prerequisites OK"

_check-docker:
	@if ! docker info > /dev/null 2>&1; then \
		echo "✗ Docker not running. Fix: open Docker Desktop."; exit 1; fi

_check-node:
	@node_major=$$(node -v 2>/dev/null | sed 's/v\([0-9]*\).*/\1/'); \
	if [ -z "$$node_major" ] || [ "$$node_major" -lt 20 ]; then \
		echo "✗ Need Node 20+. Fix: brew install node@20"; exit 1; fi

_check-env:
	@if [ ! -f .env ]; then \
		echo "✗ .env not found. Fix: cp .env.example .env and fill in real values."; exit 1; fi

# ---------- internals ----------

_db-up:
	@$(LOAD_ENV) docker compose up -d
	@echo "  Waiting for Postgres on localhost:5432..."
	@for i in $$(seq 1 30); do \
		if nc -z localhost 5432 > /dev/null 2>&1; then echo "✓ Postgres ready"; exit 0; fi; \
		sleep 1; \
	done; \
	echo "✗ Postgres did not become ready in 30s. Check 'docker compose logs db'."; exit 1

_migrate:
	@$(LOAD_ENV) npx prisma migrate deploy

_seed:
	@$(LOAD_ENV) npx prisma db seed
