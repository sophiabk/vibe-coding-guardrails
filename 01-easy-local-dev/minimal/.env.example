# acme-app — minimal environment template.
#
# In the real workflow these values come from a secrets manager at runtime
# (see the Makefile's SECRETS_RUN), so you do NOT keep a populated .env file.
# This file documents what the app expects. Every value below is a placeholder.

# --- Application ---
APP_URL=http://localhost:3000
AUTH_SECRET=replace-me-with-a-random-32-byte-string

# --- Database ---
# DATABASE_URL references PG_PASSWORD so the app and Docker agree on the password.
PG_PASSWORD=change-me-locally
DATABASE_URL=postgresql://postgres:${PG_PASSWORD}@localhost:5432/acme_app_local
