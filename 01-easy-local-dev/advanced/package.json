{
  "name": "acme-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names 'dev:next,trigger:dev,stripe:listen' --prefix '[{name}]' 'yarn dev:next' 'yarn trigger:dev' 'yarn stripe:listen'",
    "dev:next": "node scripts/copy-pdf-worker.cjs && next dev",
    "trigger:dev": "trigger dev",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "build": "node scripts/copy-pdf-worker.cjs && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test-ci": "vitest --run",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md}": "prettier --write"
  },
  "//": "Dependency versions below are ILLUSTRATIVE — pin your own. The real app has many more; these show the shape of the stack.",
  "dependencies": {
    "@prisma/client": "^5.5.2",
    "@trigger.dev/sdk": "4.4.6",
    "@trigger.dev/python": "4.4.6",
    "@stripe/stripe-js": "^4.9.0",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.25",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "prisma": "^5.5.2",
    "ts-node": "^10.9.2",
    "vitest": "^1.0.0"
  }
}
