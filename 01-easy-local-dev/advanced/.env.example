# acme-app — full environment template.
#
# In the real workflow these values come from Infisical at runtime (see the
# Makefile's INFISICAL_RUN), so you do NOT keep a populated .env file. This file
# documents every variable the app expects, grouped by concern.
# EVERY VALUE BELOW IS A PLACEHOLDER — replace with your own.

# --- Application / auth ---
APP_URL=http://localhost:3000
AUTH_SECRET=replace-me-with-a-random-32-byte-string
AUTH_URL=http://localhost:3000/api/auth
ENVIRONMENT=development

# --- Database ---
PG_PASSWORD=change-me-locally
DATABASE_URL=postgresql://postgres:${PG_PASSWORD}@localhost:5432/acme_app_local

# --- Google OAuth ---
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- AWS ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-2

# --- Stripe (test mode) ---
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=your-stripe-publishable-test-key
STRIPE_SECRET_KEY=your-stripe-secret-test-key
STRIPE_SECRET_WEBHOOK_KEY=your-stripe-webhook-signing-secret

# --- Third-party APIs ---
OPENAI_API_KEY=your-openai-api-key
SENDGRID_KEY=your-sendgrid-api-key
MAILCHIMP_API_KEY=your-mailchimp-api-key

# --- AWS SQS + S3 (file processing) ---
OCR_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/000000000000/acme-app-ocr-queue
PDF_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/000000000000/acme-app-pdf-queue
SQS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/000000000000/acme-app-app-queue
UPLOAD_BUCKET_NAME=acme-app-uploads

# --- Feature flags ---
NEXT_PUBLIC_ENABLE_PAYWALL=true
NEXT_PUBLIC_ENABLED_STATES=MA,NY
NEXT_PUBLIC_LOG_EVENTS=true

# --- PDF-to-Markdown Lambda ---
PDF2MD_HOST=https://your-lambda-url.lambda-url.us-east-2.on.aws
PDF2MD_TOKEN=your-lambda-shared-secret

# --- LLM inference (AWS Bedrock) ---
BEDROCK_MODEL_ID=arn:aws:bedrock:us-east-2:000000000000:inference-profile/your-model-id
HIGHLIGHT_MODEL_ID=arn:aws:bedrock:us-east-2:000000000000:inference-profile/your-model-id
